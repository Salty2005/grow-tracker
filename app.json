{
  "expo": {
    "name": "Grow Tracker",
    "slug": "grow-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "grow-tracker",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.growtracker.app"
    },
    "android": {
      "package": "com.growtracker.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "./plugins/withScreenCapturePermission"
    ]
  }
}
